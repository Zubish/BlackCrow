{
  "buildCommand": "npm run build && npm run check",
  "outputDirectory": "public",
  "functions": {
    "api/[...path].js": {
      "includeFiles": "backend/schema.sql",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/landingpage.html"
    }
  ]
}
