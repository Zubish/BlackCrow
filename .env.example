PORT=5000
NODE_ENV=development
ALLOWED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
PUBLIC_APP_URL=http://127.0.0.1:5000
INTERNAL_API_SECRET=

# Leave DATABASE_URL empty to use backend/data.json for local development.
# Set this to your Neon pooled connection string when you are ready for cloud Postgres.
DATABASE_URL=
DATABASE_SSL=true

# Optional until real email delivery is needed. In development, OTP codes are still returned for testing.
RESEND_API_KEY=
RESEND_FROM_EMAIL=BlackCrow <onboarding@resend.dev>

# simulated is the default. Set PAYMENT_PROVIDER=paystack only after adding PAYSTACK_SECRET_KEY.
PAYMENT_PROVIDER=simulated
PAYSTACK_SECRET_KEY=
